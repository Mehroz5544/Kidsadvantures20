<body class="bg-background text-on-background font-body-btm min-h-screen flex flex-col md:flex-row overflow-x-hidden">
<!-- NavigationDrawer (Desktop) -->
<aside class="hidden md:flex flex-col bg-surface-bright border-r-4 border-surface-variant shadow-xl h-full w-80 rounded-r-lg fixed inset-y-0 left-0 z-[60]">
<div class="flex flex-col items-center justify-center p-gutter border-b border-surface-variant">
<div class="w-32 h-32 rounded-full bg-primary-container border-4 border-surface-variant overflow-hidden mb-4 shadow-[0_4px_0_0_rgba(124,88,0,0.2)]">
<img alt="Floating Animal Teacher" class="w-full h-full object-cover" data-alt="A 3D stylized friendly rabbit character wearing glasses and a bowtie, smiling warmly. Bright colors, soft lighting, feeling safe and educational. High quality rendering." src="https://lh3.googleusercontent.com/aida-public/AB6AXuDkEcr11idRIcgwb_P6GmqJDOBSoX4zWCueqTNyB08ZtvOxrKxqgB0zqZ0_Yn8faJtrDM7JMZHaJvCbR7ryrMEva-LYFmCmSsIUI9zdgJeZfYq3tDcm5AbweWCTylu7rjWFAHObVmnxeSx_akeWnQicIQLUNMznQTyKcmCXCyxYs0srxiGUt-Xdg9uy8EFAyR-jBO-FuqDzjcJN1Q15qYkrF_6ESnWSxp0CoRQoPwMmC689Zvlb97o-"/>
</div>
<h2 class="text-headline-lg font-headline-lg text-primary text-center">Professor Paws</h2>
<p class="text-body-btm font-body-btm text-on-surface-variant text-center">Level 5 Explorer</p>
<div class="mt-4 flex items-center gap-2 bg-surface-container-high px-4 py-2 rounded-full border-2 border-primary-container shadow-sm">
<span class="material-symbols-outlined text-primary-container" style="font-variation-settings: 'FILL' 1;">stars</span>
<span class="text-label-caps font-label-caps text-on-surface">1,240 Coins</span>
</div>
</div>
<nav class="flex-1 overflow-y-auto p-4 flex flex-col gap-2">
<a class="flex items-center gap-4 bg-tertiary-container text-on-tertiary-container rounded-lg m-2 p-4 border-b-4 border-tertiary hover:bg-surface-container-high transition-colors active:translate-x-1" href="#">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">map</span>
<span class="text-headline-lg font-headline-lg">World Map</span>
</a>
<a class="flex items-center gap-4 text-on-surface-variant p-4 m-2 hover:bg-surface-container-high transition-colors rounded-lg active:translate-x-1" href="#">
<span class="material-symbols-outlined">auto_awesome</span>
<span class="text-headline-lg font-headline-lg">My Stickers</span>
</a>
<a class="flex items-center gap-4 text-on-surface-variant p-4 m-2 hover:bg-surface-container-high transition-colors rounded-lg active:translate-x-1" href="#">
<span class="material-symbols-outlined">family_restroom</span>
<span class="text-headline-lg font-headline-lg">Parent Zone</span>
</a>
