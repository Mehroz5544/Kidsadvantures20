<span class="material-symbols-outlined">help</span>
<span class="text-headline-lg font-headline-lg">Help</span>
</a>
</nav>
</aside>
<!-- Main Content Canvas -->
<main class="flex-1 flex flex-col min-h-screen relative md:ml-80 pb-[100px] md:pb-0 pt-[80px] md:pt-0">
<!-- TopAppBar (Mobile) -->
<header class="md:hidden fixed top-0 left-0 w-full z-50 flex justify-between items-center px-margin-mobile py-4 bg-surface-container border-b-4 border-surface-variant shadow-[0_4px_0_0_rgba(124,88,0,0.2)]">
<button class="w-12 h-12 flex items-center justify-center rounded-full bg-surface-container-high border-2 border-surface-variant text-primary hover:translate-y-0.5 transition-transform active:translate-y-1 active:border-b-0 bubbly-button">
<span class="material-symbols-outlined">arrow_back</span>
</button>
<h1 class="text-headline-lg-mobile font-headline-lg-mobile text-primary text-center flex-1 mx-4 truncate">Magic Map</h1>
<div class="flex items-center gap-2 bg-surface-bright px-3 py-2 rounded-xl border-2 border-surface-variant shadow-sm text-label-caps font-label-caps text-on-surface">
<span>125</span>
<span class="material-symbols-outlined text-primary-container" style="font-variation-settings: 'FILL' 1;">star</span>
</div>
</header>
<!-- The Map Area -->
<div class="flex-1 relative overflow-hidden bg-surface-dim">
<!-- Background Pattern -->
<div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: radial-gradient(#7c5800 2px, transparent 2px); background-size: 32px 32px;"></div>
<!-- SVG Path connecting worlds -->
<svg class="absolute inset-0 w-full h-full pointer-events-none" preserveaspectratio="xMidYMid slice" viewbox="0 0 1000 1000">
<path d="M 100 800 C 300 800, 200 500, 500 500 C 800 500, 700 200, 900 200" fill="none" stroke="#ffdcbc" stroke-linecap="round" stroke-width="40"></path>
<path class="dash-path" d="M 100 800 C 300 800, 200 500, 500 500 C 800 500, 700 200, 900 200" fill="none" stroke="#ffba20" stroke-linecap="round" stroke-width="12"></path>
</svg>
<!-- Map Nodes -->
<div class="relative w-full h-[800px] max-w-4xl mx-auto mt-gutter-desktop">
<!-- Start / Professor Paws -->
<div class="absolute bottom-[10%] left-[5%] flex flex-col items-center">
<div class="w-32 h-32 floating">
<img alt="Start" class="w-full h-full object-contain" data-alt="A small 3D rendering of a cute bunny standing on a grassy patch, waving cheerfully. Bright colors, soft lighting, engaging for children." src="https://lh3.googleusercontent.com/aida-public/AB6AXuAFlzQM3KP_Clu20s0Sxn7kch_Ssp5ZJ9Zzz9-pRx13SeLuVa7_OaBRJ7dnDff83R3j9Ik6XK_BaqK12kdpt7dC0lzYgdAGsiqlJkgWZ0UUK44CAjC0MQzKKmfNDWA5KNoimiTUjLdih8KglWrtLk__W2kwN2xQvGIcx7XpZ9eCqOVEkyNuHphledtuZ6mDAZ_xxRNaBr262mTlMwtFZ7reIaAF9eGIA9SDZfgacSBxMn3-Np-9__68"/>
</div>
<div class="bg-surface-bright px-4 py-2 rounded-full border-4 border-surface-variant text-label-caps font-label-caps shadow-lg mt-2 text-primary">Start Here!</div>
</div>
<!-- World 1: Alphabet Forest -->
<button class="absolute bottom-[30%] left-[25%] flex flex-col items-center group hover:scale-110 transition-transform bubbly-button border-b-8 border-tertiary rounded-3xl bg-tertiary-container p-4 w-48 shadow-xl">
<div class="w-24 h-24 mb-2 bg-surface-bright rounded-2xl border-4 border-tertiary flex items-center justify-center">
<span class="material-symbols-outlined text-6xl text-tertiary" style="font-variation-settings: 'FILL' 1;">forest</span>
</div>
<span class="text-headline-lg-mobile font-headline-lg-mobile text-on-tertiary-container text-center leading-tight">Alphabet<br/>Forest</span>
<!-- Floating Go Button (Active Level) -->
<div class="absolute -top-4 -right-4 bg-primary-container text-on-primary-container w-16 h-16 rounded-full border-4 border-surface-bright flex items-center justify-center shadow-lg transform rotate-12 floating">
<span class="text-label-caps font-label-caps font-black">GO!</span>
</div>
</button>
<!-- World 2: Number Mountain -->
<button class="absolute top-[40%] left-[45%] flex flex-col items-center group hover:scale-110 transition-transform bubbly-button border-b-8 border-secondary rounded-3xl bg-secondary-container p-4 w-48 shadow-xl opacity-70 grayscale-[30%]">
<div class="w-24 h-24 mb-2 bg-surface-bright rounded-2xl border-4 border-secondary flex items-center justify-center">
<span class="material-symbols-outlined text-6xl text-secondary" style="font-variation-settings: 'FILL' 1;">landscape</span>
</div>
<span class="text-headline-lg-mobile font-headline-lg-mobile text-on-secondary-container text-center leading-tight">Number<br/>Mountain</span>
<div class="absolute inset-0 bg-surface-variant/20 rounded-3xl flex items-center justify-center backdrop-blur-[2px]">
<span class="material-symbols-outlined text-4xl text-on-surface-variant bg-surface-bright p-2 rounded-full border-2 border-surface-variant shadow-sm" style="font-variation-settings: 'FILL' 1;">lock</span>
</div>
</button>
<!-- World 3: Shape Island -->
<button class="absolute top-[15%] right-[10%] flex flex-col items-center group hover:scale-110 transition-transform bubbly-button border-b-8 border-primary rounded-3xl bg-primary-container p-4 w-48 shadow-xl opacity-70 grayscale-[30%]">
<div class="w-24 h-24 mb-2 bg-surface-bright rounded-2xl border-4 border-primary flex items-center justify-center">
<span class="material-symbols-outlined text-6xl text-primary" style="font-variation-settings: 'FILL' 1;">category</span>
