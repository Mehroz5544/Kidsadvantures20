<script>
        let currentPin = '';
        const targetPin = '1234'; // Dummy PIN for demo

        function updateDots() {
            const dots = document.querySelectorAll('.pin-dot');
            dots.forEach((dot, index) => {
                if (index < currentPin.length) {
                    dot.classList.remove('bg-surface-variant', 'border-outline-variant');
                    dot.classList.add('bg-primary', 'border-primary');
                } else {
                    dot.classList.add('bg-surface-variant', 'border-outline-variant');
                    dot.classList.remove('bg-primary', 'border-primary');
                }
            });
        }

        function enterPin(num) {
            if (currentPin.length < 4) {
                currentPin += num;
                updateDots();
                
                if (currentPin.length === 4) {
                    setTimeout(() => {
                        if (currentPin === targetPin || true) { // Always pass for this UI demo
                            document.getElementById('pin-screen').style.display = 'none';
                            document.getElementById('dashboard-content').style.display = 'block';
                        } else {
                            // Shake animation could go here
                            currentPin = '';
                            updateDots();
                        }
                    }, 300);
                }
            }
        }

        function clearPin() {
            currentPin = '';
            updateDots();
        }
    </script>
