<style>
        /* CSS Animations for celebration */
        @keyframes bounce-in {
            0% { transform: scale(0.1); opacity: 0; }
            60% { transform: scale(1.2); opacity: 1; }
            100% { transform: scale(1); opacity: 1; }
        }
        @keyframes float {
            0% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(5deg); }
            100% { transform: translateY(0px) rotate(0deg); }
        }
        @keyframes pulse-glow {
            0% { box-shadow: 0 0 0 0 rgba(255, 184, 0, 0.7); }
            70% { box-shadow: 0 0 0 20px rgba(255, 184, 0, 0); }
            100% { box-shadow: 0 0 0 0 rgba(255, 184, 0, 0); }
        }
        @keyframes pop {
            0% { transform: scale(1); }
            50% { transform: scale(1.1); }
            100% { transform: scale(1); }
        }
        
        .animate-bounce-in { animation: bounce-in 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; }
        .animate-float { animation: float 4s ease-in-out infinite; }
        .animate-pulse-glow { animation: pulse-glow 2s infinite; }
        .pop-on-hover:hover { animation: pop 0.3s ease-in-out; }
        
        /* 3D Button Effects */
        .btn-3d {
            transition: all 0.1s ease;
            position: relative;
            top: 0;
        }
        .btn-3d:active {
            top: 4px;
            box-shadow: none !important;
            transform: translateY(4px);
        }
        
        /* Confetti effect using background */
        .confetti-bg {
            background-image: 
                radial-gradient(circle at 20% 30%, #ffba20 4px, transparent 5px),
                radial-gradient(circle at 80% 20%, #53df69 6px, transparent 7px),
                radial-gradient(circle at 40% 70%, #00c1fd 5px, transparent 6px),
                radial-gradient(circle at 70% 80%, #ffba20 5px, transparent 6px),
                radial-gradient(circle at 10% 80%, #00c1fd 6px, transparent 7px),
                radial-gradient(circle at 90% 50%, #53df69 4px, transparent 5px);
            background-size: 200px 200px;
            animation: bg-scroll 20s linear infinite;
        }
        @keyframes bg-scroll {
            0% { background-position: 0 0; }
            100% { background-position: 200px 200px; }
        }

        /* Hide scrollbar */
        body { overflow: hidden; }
    </style>
