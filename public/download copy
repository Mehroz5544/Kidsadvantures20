<!-- Drop Zone (Outline of Number 1) -->
<div class="relative z-10 w-48 h-64 mt-16 flex items-center justify-center border-8 border-dashed border-outline-variant rounded-xl bg-surface-container-low/50 backdrop-blur-sm pulse-outline" id="dropzone">
<span class="text-[120px] font-display-hero text-outline-variant opacity-30 select-none">1</span>
</div>
<!-- Draggable Numbers Container -->
<div class="absolute bottom-12 w-full flex justify-center gap-gutter px-gutter z-30">
<!-- Draggable Number 1 -->
<div class="w-32 h-32 bg-secondary text-on-secondary rounded-xl flex items-center justify-center shadow-[0_8px_0_0_#004b65] active:shadow-none active:translate-y-2 transition-all cursor-grab float-anim" draggable="true" id="draggable-1">
<span class="text-[80px] font-display-hero leading-none">1</span>
</div>
<!-- Draggable Number 2 -->
<div class="w-32 h-32 bg-primary-container text-on-primary-container rounded-xl flex items-center justify-center shadow-[0_8px_0_0_#7c5800] active:shadow-none active:translate-y-2 transition-all cursor-grab float-anim-delay" draggable="true" id="draggable-2">
<span class="text-[80px] font-display-hero leading-none">2</span>
</div>
</div>
</main>
<script>
        // Simple Drag and Drop Logic for demonstration
        const draggables = document.querySelectorAll('[draggable="true"]');
        const dropzone = document.getElementById('dropzone');

        draggables.forEach(draggable => {
            draggable.addEventListener('dragstart', () => {
                draggable.classList.add('opacity-50');
                draggable.classList.remove('float-anim', 'float-anim-delay');
            });

            draggable.addEventListener('dragend', () => {
                draggable.classList.remove('opacity-50');
            });
        });

        dropzone.addEventListener('dragover', e => {
            e.preventDefault(); // Necessary to allow dropping
            dropzone.classList.replace('border-outline-variant', 'border-primary');
            dropzone.classList.replace('bg-surface-container-low/50', 'bg-surface-variant/80');
        });

        dropzone.addEventListener('dragleave', () => {
            dropzone.classList.replace('border-primary', 'border-outline-variant');
            dropzone.classList.replace('bg-surface-variant/80', 'bg-surface-container-low/50');
        });

        dropzone.addEventListener('drop', e => {
            e.preventDefault();
            // Basic simulation of success
            dropzone.innerHTML = '<span class="text-[120px] font-display-hero text-primary select-none">1</span>';
            dropzone.classList.remove('border-dashed', 'pulse-outline');
            dropzone.classList.add('border-solid', 'border-primary', 'bg-surface-container-high', 'scale-110', 'transition-transform');
            
            const num1 = document.getElementById('draggable-1');
            if(num1) num1.style.display = 'none';

            // Trigger basic confetti effect (simulated with alert or console for this environment)
            console.log("Success! Confetti triggered.");
            // In a real implementation, a JS confetti library would be called here.
        });
    </script>
